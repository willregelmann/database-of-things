{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Magic: The Gathering card attributes",
  "type": "object",
  "properties": {
    "number": { "type": "string", "pattern": "^[0-9]+[a-z]?(/[0-9]+)?$" },
    "rarity": {
      "type": "string",
      "enum": ["Common", "Uncommon", "Rare", "Mythic", "Special", "Bonus", "Land"]
    },
    "colors": {
      "type": "array",
      "items": { "type": "string", "enum": ["W", "U", "B", "R", "G"] }
    },
    "mana_cost": { "type": "string" },
    "card_type": { "type": "string" },
    "illustrator": { "type": "string" }
  },
  "additionalProperties": true
}
