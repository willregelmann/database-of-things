{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pokemon TCG card attributes",
  "type": "object",
  "properties": {
    "number": { "type": "string", "pattern": "^([0-9]+|[A-Z]|[!?])/[0-9]+$" },
    "rarity": {
      "type": "string",
      "enum": ["Common", "Uncommon", "Rare", "Holo Rare", "Rare Holo EX", "Rare Holo ☆", "Secret Rare", "Promo"]
    },
    "illustrator": { "type": "string" }
  },
  "additionalProperties": true
}
