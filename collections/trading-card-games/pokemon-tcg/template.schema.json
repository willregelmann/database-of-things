{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pokemon TCG card attributes",
  "type": "object",
  "properties": {
    "number": { "type": "string", "pattern": "^(H?[0-9]+|[A-Z]|[!?])/H?[0-9]+$|^[A-Z]{1,3}[0-9]+$" },
    "rarity": {
      "type": "string",
      "enum": ["Common", "Uncommon", "Rare", "Rare Holo", "Rare Holo ex", "Rare Holo ☆", "Rare Holo LV.X", "Secret Rare", "Shining Holofoil", "Promo"]
    },
    "illustrator": { "type": "string" }
  },
  "additionalProperties": true
}
