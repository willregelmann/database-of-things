{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "figma attributes",
  "type": "object",
  "properties": {
    "number": { "type": "string", "pattern": "^(SP|EX)?[0-9]{3,4}[A-Za-z]?$" },
    "origin": { "type": "string" },
    "manufacturer": { "type": "string" },
    "sculptor": { "type": "string" },
    "release_type": {
      "type": "string",
      "enum": ["Standard", "Exclusive", "Limited"]
    }
  },
  "additionalProperties": true
}
