{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nendoroid attributes",
  "type": "object",
  "properties": {
    "number": { "type": "string", "pattern": "^[0-9]{1,4}[A-Za-z]?(-DX)?$" },
    "origin": { "type": "string" },
    "manufacturer": { "type": "string" },
    "sculptor": { "type": "string" },
    "release_type": {
      "type": "string",
      "enum": ["Standard", "Exclusive", "Limited"]
    }
  },
  "additionalProperties": true
}
