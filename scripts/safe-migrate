#!/bin/bash
set -euo pipefail

# Safe migration wrapper
# Automatically creates a backup before running database migrations

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

COMMAND="${1:-push}"

if [[ "$COMMAND" != "push" && "$COMMAND" != "reset" ]]; then
    echo -e "${RED}Error: Invalid command. Use 'push' or 'reset'${NC}"
    echo "Usage: $0 [push|reset]"
    echo ""
    echo "  push  - Apply new migrations (non-destructive)"
    echo "  reset - Reset database and rerun all migrations (DESTRUCTIVE)"
    exit 1
fi

# Check if Supabase is running
if ! docker ps | grep -q supabase_db_database-of-things; then
    echo -e "${RED}Error: Supabase is not running. Start it with: ./bin/supabase start${NC}"
    exit 1
fi

# Warn for destructive operations
if [ "$COMMAND" = "reset" ]; then
    echo -e "${RED}⚠️  WARNING: 'db reset' will DELETE ALL DATA and recreate the database!${NC}"
    echo ""
    read -p "Are you absolutely sure you want to reset? (type 'RESET' to confirm): " -r
    echo
    
    if [[ $REPLY != "RESET" ]]; then
        echo "Reset cancelled."
        exit 0
    fi
fi

# Create backup before migration
echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}Step 1: Creating backup before migration${NC}"
echo -e "${BLUE}========================================${NC}"
./scripts/db-backup

if [ $? -ne 0 ]; then
    echo -e "${RED}✗ Backup failed. Aborting migration.${NC}"
    exit 1
fi

# Run the migration
echo ""
echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}Step 2: Running migration${NC}"
echo -e "${BLUE}========================================${NC}"

if [ "$COMMAND" = "push" ]; then
    ./bin/supabase db push
else
    ./bin/supabase db reset
fi

MIGRATION_EXIT_CODE=$?

if [ $MIGRATION_EXIT_CODE -eq 0 ]; then
    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}✓ Migration completed successfully!${NC}"
    echo -e "${GREEN}========================================${NC}"
else
    echo ""
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}✗ Migration failed!${NC}"
    echo -e "${RED}========================================${NC}"
    echo -e "${YELLOW}To restore from backup, run:${NC}"
    echo -e "  ./scripts/db-restore backups/backup_*.sql"
    exit $MIGRATION_EXIT_CODE
fi
