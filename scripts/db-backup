#!/bin/bash
set -euo pipefail

# Database backup script
# Creates a timestamped dump of the PostgreSQL database

BACKUP_DIR="backups"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/backup_${TIMESTAMP}.sql"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Creating database backup...${NC}"

# Check if Supabase is running
if ! docker ps | grep -q supabase_db_database-of-things; then
    echo -e "${RED}Error: Supabase is not running. Start it with: ./bin/supabase start${NC}"
    exit 1
fi

# Create backup directory if it doesn't exist
mkdir -p "${BACKUP_DIR}"

# Create the backup
echo -e "Backing up to: ${BACKUP_FILE}"
docker exec supabase_db_database-of-things pg_dump -U postgres -d postgres --clean --if-exists > "${BACKUP_FILE}"

# Check if backup was successful
if [ -s "${BACKUP_FILE}" ]; then
    SIZE=$(du -h "${BACKUP_FILE}" | cut -f1)
    echo -e "${GREEN}✓ Backup created successfully: ${BACKUP_FILE} (${SIZE})${NC}"
    echo -e "${GREEN}✓ To restore: ./scripts/db-restore ${BACKUP_FILE}${NC}"
else
    echo -e "${RED}✗ Backup failed - file is empty${NC}"
    rm -f "${BACKUP_FILE}"
    exit 1
fi
