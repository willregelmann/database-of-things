#!/bin/bash

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
BACKUP_DIR="backups/storage"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/storage_${TIMESTAMP}.tar.gz"
VOLUME_NAME="supabase_storage_database-of-things"

# Create backup directory if it doesn't exist
mkdir -p "${BACKUP_DIR}"

echo -e "${YELLOW}Creating storage backup...${NC}"
echo "Backing up to: ${BACKUP_FILE}"

# Create temporary container to access volume
TEMP_CONTAINER="temp_storage_backup_${TIMESTAMP}"

# Export volume contents to tarball
docker run --rm \
  -v "${VOLUME_NAME}:/data:ro" \
  -v "$(pwd)/${BACKUP_DIR}:/backup" \
  --name "${TEMP_CONTAINER}" \
  alpine:latest \
  tar czf "/backup/storage_${TIMESTAMP}.tar.gz" -C /data .

# Get file size
BACKUP_SIZE=$(du -h "${BACKUP_FILE}" | cut -f1)

echo -e "${GREEN}✓ Storage backup created successfully: ${BACKUP_FILE} (${BACKUP_SIZE})${NC}"
echo -e "${GREEN}✓ To restore: ./scripts/storage-restore ${BACKUP_FILE}${NC}"
