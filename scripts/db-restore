#!/bin/bash
set -euo pipefail

# Database restore script
# Restores a PostgreSQL database from a backup file

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

if [ $# -eq 0 ]; then
    echo -e "${RED}Error: No backup file specified${NC}"
    echo "Usage: $0 <backup-file.sql>"
    echo ""
    echo "Available backups:"
    ls -lh backups/*.sql 2>/dev/null | awk '{print "  " $9 " (" $5 ")"}'
    exit 1
fi

BACKUP_FILE="$1"

# Check if backup file exists
if [ ! -f "${BACKUP_FILE}" ]; then
    echo -e "${RED}Error: Backup file not found: ${BACKUP_FILE}${NC}"
    exit 1
fi

# Check if Supabase is running
if ! docker ps | grep -q supabase_db_database-of-things; then
    echo -e "${RED}Error: Supabase is not running. Start it with: ./bin/supabase start${NC}"
    exit 1
fi

echo -e "${YELLOW}⚠️  WARNING: This will overwrite your current database!${NC}"
echo -e "Restoring from: ${BACKUP_FILE}"
echo ""
read -p "Are you sure you want to continue? (yes/no): " -r
echo

if [[ ! $REPLY =~ ^[Yy][Ee][Ss]$ ]]; then
    echo "Restore cancelled."
    exit 0
fi

# Create a safety backup of current state
SAFETY_BACKUP="backups/pre-restore_$(date +%Y%m%d_%H%M%S).sql"
echo -e "${YELLOW}Creating safety backup of current database...${NC}"
docker exec supabase_db_database-of-things pg_dump -U postgres -d postgres --clean --if-exists > "${SAFETY_BACKUP}"
echo -e "${GREEN}✓ Safety backup created: ${SAFETY_BACKUP}${NC}"

# Restore the backup
echo -e "${YELLOW}Restoring database...${NC}"
docker exec -i supabase_db_database-of-things psql -U postgres -d postgres < "${BACKUP_FILE}"

echo -e "${GREEN}✓ Database restored successfully from: ${BACKUP_FILE}${NC}"
echo -e "${GREEN}✓ Safety backup available at: ${SAFETY_BACKUP}${NC}"
