#!/bin/bash

# Wrapper script for easy thumbnail generation
# Usage: ./scripts/generate-all-thumbnails [options]

set -e  # Exit on error

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
THUMBNAIL_DIR="$SCRIPT_DIR/thumbnails"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}╔════════════════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║${NC}           ${GREEN}Thumbnail Generation Wizard${NC}                           ${BLUE}║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Check for Supabase CLI or .env
echo -e "${BLUE}🔍 Checking credentials...${NC}"

if command -v supabase &> /dev/null; then
    # Check if project is linked
    if supabase projects list 2>&1 | grep -q "●"; then
        PROJECT=$(supabase projects list 2>&1 | grep "●" | awk '{print $6}' | head -1)
        echo -e "${GREEN}✅ Found linked Supabase project: $PROJECT${NC}"
        echo -e "${BLUE}   Credentials will be auto-detected from CLI${NC}"
    else
        echo -e "${YELLOW}⚠️  Supabase CLI found but no project linked${NC}"
        echo ""
        echo "Would you like to:"
        echo "  A. Link to Supabase project (recommended)"
        echo "  B. Use .env file instead"
        echo ""
        read -p "Choice [A/B]: " cred_choice
        if [[ $cred_choice =~ ^[Aa]$ ]]; then
            echo ""
            echo "Running: supabase link"
            supabase link
            if [ $? -ne 0 ]; then
                echo -e "${RED}Failed to link project${NC}"
                exit 1
            fi
        elif [[ $cred_choice =~ ^[Bb]$ ]]; then
            if [ ! -f "$THUMBNAIL_DIR/.env" ]; then
                cp "$THUMBNAIL_DIR/.env.example" "$THUMBNAIL_DIR/.env"
                echo -e "${YELLOW}Created .env template. Please edit it with your credentials.${NC}"
                exit 1
            fi
        else
            echo -e "${RED}Invalid choice${NC}"
            exit 1
        fi
    fi
elif [ -f "$THUMBNAIL_DIR/.env" ]; then
    echo -e "${GREEN}✅ Found .env file${NC}"
    echo -e "${BLUE}   Credentials will be loaded from .env${NC}"
else
    echo -e "${RED}❌ No credentials found!${NC}"
    echo ""
    echo "You need either:"
    echo "  A. Supabase CLI with linked project: brew install supabase/tap/supabase && supabase link"
    echo "  B. .env file with credentials"
    echo ""
    exit 1
fi

echo ""

# Check if node_modules exists
if [ ! -d "$THUMBNAIL_DIR/node_modules" ]; then
    echo -e "${BLUE}📦 Installing dependencies...${NC}"
    cd "$THUMBNAIL_DIR"
    npm install --silent
    cd - > /dev/null
    echo -e "${GREEN}✅ Dependencies installed${NC}"
    echo ""
fi

# Parse arguments or show menu
if [ $# -eq 0 ]; then
    echo "What would you like to do?"
    echo ""
    echo "  1) Test with 5 images (dry-run)"
    echo "  2) Process first 100 images"
    echo "  3) Process ALL images (full backfill)"
    echo "  4) Resume (skip images that already have thumbnails)"
    echo "  5) Custom command"
    echo "  6) Exit"
    echo ""
    read -p "Enter choice [1-6]: " choice

    case $choice in
        1)
            echo ""
            echo -e "${BLUE}🧪 Running test with 5 images (dry-run)...${NC}"
            echo ""
            cd "$THUMBNAIL_DIR"
            npm run backfill -- --dry-run --limit=5
            ;;
        2)
            echo ""
            echo -e "${BLUE}🚀 Processing first 100 images...${NC}"
            echo ""
            read -p "Are you sure? This will upload thumbnails to Supabase. [y/N]: " confirm
            if [[ $confirm =~ ^[Yy]$ ]]; then
                cd "$THUMBNAIL_DIR"
                npm run backfill -- --limit=100
            else
                echo "Cancelled."
                exit 0
            fi
            ;;
        3)
            echo ""
            echo -e "${YELLOW}⚠️  WARNING: This will process ALL images in your database!${NC}"
            echo ""
            read -p "Are you absolutely sure? [y/N]: " confirm
            if [[ $confirm =~ ^[Yy]$ ]]; then
                echo ""
                echo -e "${BLUE}🚀 Processing ALL images...${NC}"
                echo ""
                cd "$THUMBNAIL_DIR"
                npm run backfill
            else
                echo "Cancelled."
                exit 0
            fi
            ;;
        4)
            echo ""
            echo -e "${BLUE}🔄 Resume mode (skipping existing thumbnails)...${NC}"
            echo ""
            cd "$THUMBNAIL_DIR"
            npm run backfill -- --resume
            ;;
        5)
            echo ""
            echo "Available options:"
            echo "  --dry-run      - Preview without making changes"
            echo "  --limit=N      - Process only first N entities"
            echo "  --batch=N      - Process N entities at a time (default: 10)"
            echo "  --parallel=N   - Concurrent operations (default: 3)"
            echo "  --size=300     - Thumbnail size (default: 300)"
            echo "  --quality=85   - WebP quality (default: 85)"
            echo "  --resume       - Skip existing thumbnails"
            echo ""
            read -p "Enter custom options: " custom_opts
            cd "$THUMBNAIL_DIR"
            npm run backfill -- $custom_opts
            ;;
        6)
            echo "Goodbye!"
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid choice${NC}"
            exit 1
            ;;
    esac
else
    # Pass all arguments directly to backfill script
    echo -e "${BLUE}🚀 Running with custom options...${NC}"
    echo ""
    cd "$THUMBNAIL_DIR"
    npm run backfill -- "$@"
fi

echo ""
echo -e "${GREEN}✨ Done!${NC}"
