# Supabase Configuration
# Copy this to .env and fill in your actual values

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service role key (NOT the anon key!) - required for bypassing RLS
# Find this in Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# WARNING: The service_role key bypasses Row Level Security (RLS)
# Never commit this file or expose it publicly!
