#!/bin/bash

# Embedding System Management Script
# Provides easy access to common embedding operations

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Database connection
DB_CONTAINER="supabase_db_database-of-things"
PSQL_CMD="docker exec $DB_CONTAINER psql -U postgres -d postgres"

# Functions
show_help() {
    cat << EOF
Embedding System Management

Usage: $0 [command] [options]

Commands:
    status              Show queue statistics and worker status
    start               Start the embedding worker
    stop                Stop the embedding worker
    restart             Restart the embedding worker
    logs                Show worker logs
    queue-all           Queue all entities missing embeddings
    queue-batch [n]     Queue n entities missing embeddings
    retry-failed        Retry failed queue items
    cleanup             Clean up old completed queue items
    backfill            Interactive backfill process
    stats               Detailed statistics
    monitor             Live monitoring (updates every 5s)

Options:
    -h, --help          Show this help message

Examples:
    $0 status           # Show current status
    $0 queue-batch 100  # Queue 100 entities
    $0 monitor          # Live monitoring
EOF
}

check_docker() {
    if ! docker ps > /dev/null 2>&1; then
        echo -e "${RED}Error: Docker is not running or not accessible${NC}"
        exit 1
    fi
}

check_database() {
    if ! docker ps | grep -q $DB_CONTAINER; then
        echo -e "${RED}Error: Database container is not running${NC}"
        echo "Run: ./bin/supabase start"
        exit 1
    fi
}

show_status() {
    echo -e "${BLUE}=== Embedding Queue Status ===${NC}"
    $PSQL_CMD -c "SELECT * FROM embedding_queue_stats;"

    echo -e "\n${BLUE}=== Entities Missing Embeddings ===${NC}"
    $PSQL_CMD -c "SELECT COUNT(*) as missing_count FROM entities_missing_embeddings;"

    echo -e "\n${BLUE}=== Worker Status ===${NC}"
    if docker ps | grep -q embedding_worker; then
        echo -e "${GREEN}Worker is running${NC}"
        docker ps --filter "name=embedding_worker" --format "table {{.Names}}\t{{.Status}}\t{{.Size}}"
    else
        echo -e "${YELLOW}Worker is not running${NC}"
    fi
}

start_worker() {
    echo -e "${BLUE}Starting embedding worker...${NC}"
    docker-compose -f docker-compose.embedding.yml up -d --build
    sleep 3
    if docker ps | grep -q embedding_worker; then
        echo -e "${GREEN}Worker started successfully${NC}"
    else
        echo -e "${RED}Failed to start worker${NC}"
        docker-compose -f docker-compose.embedding.yml logs --tail 50
    fi
}

stop_worker() {
    echo -e "${BLUE}Stopping embedding worker...${NC}"
    docker-compose -f docker-compose.embedding.yml stop
    echo -e "${GREEN}Worker stopped${NC}"
}

restart_worker() {
    echo -e "${BLUE}Restarting embedding worker...${NC}"
    docker-compose -f docker-compose.embedding.yml restart
    echo -e "${GREEN}Worker restarted${NC}"
}

show_logs() {
    echo -e "${BLUE}=== Worker Logs ===${NC}"
    docker-compose -f docker-compose.embedding.yml logs --tail ${1:-100} -f
}

queue_all() {
    echo -e "${BLUE}Queuing all entities missing embeddings...${NC}"
    result=$($PSQL_CMD -t -c "SELECT queue_missing_embeddings(NULL, NULL);")
    echo -e "${GREEN}Queued $result entities${NC}"
}

queue_batch() {
    local batch_size=${1:-100}
    echo -e "${BLUE}Queuing $batch_size entities missing embeddings...${NC}"
    result=$($PSQL_CMD -t -c "SELECT queue_missing_embeddings(NULL, $batch_size);")
    echo -e "${GREEN}Queued $result entities${NC}"
}

retry_failed() {
    echo -e "${BLUE}Retrying failed queue items...${NC}"
    result=$($PSQL_CMD -t -c "SELECT retry_failed_embeddings(24);")
    echo -e "${GREEN}Reset $result items to pending${NC}"
}

cleanup_queue() {
    echo -e "${BLUE}Cleaning up old completed queue items...${NC}"
    result=$($PSQL_CMD -t -c "SELECT cleanup_old_queue_items(7);")
    echo -e "${GREEN}Removed $result old items${NC}"
}

show_stats() {
    echo -e "${BLUE}=== Detailed Statistics ===${NC}"

    echo -e "\n${YELLOW}Queue by Status:${NC}"
    $PSQL_CMD -c "
    SELECT status, COUNT(*) as count,
           MIN(created_at)::timestamp(0) as oldest,
           MAX(created_at)::timestamp(0) as newest
    FROM embedding_queue
    GROUP BY status
    ORDER BY status;"

    echo -e "\n${YELLOW}Processing Performance (last hour):${NC}"
    $PSQL_CMD -c "
    SELECT
        COUNT(*) as processed,
        ROUND(AVG(EXTRACT(EPOCH FROM (processed_at - created_at))), 2) as avg_seconds,
        ROUND(MIN(EXTRACT(EPOCH FROM (processed_at - created_at))), 2) as min_seconds,
        ROUND(MAX(EXTRACT(EPOCH FROM (processed_at - created_at))), 2) as max_seconds
    FROM embedding_queue
    WHERE status = 'completed'
    AND processed_at > NOW() - INTERVAL '1 hour';"

    echo -e "\n${YELLOW}Failed Items:${NC}"
    $PSQL_CMD -c "
    SELECT entity_name, attempts, LEFT(last_error, 50) as error
    FROM embedding_queue
    WHERE status = 'failed'
    ORDER BY created_at DESC
    LIMIT 5;"

    echo -e "\n${YELLOW}Entity Coverage:${NC}"
    $PSQL_CMD -c "
    SELECT type,
           COUNT(*) as total,
           COUNT(name_embedding) as with_embedding,
           ROUND(100.0 * COUNT(name_embedding) / COUNT(*), 2) as percentage
    FROM entities
    WHERE name IS NOT NULL
    GROUP BY type
    ORDER BY total DESC
    LIMIT 10;"
}

interactive_backfill() {
    echo -e "${BLUE}=== Interactive Backfill Process ===${NC}"

    # Check current status
    missing=$($PSQL_CMD -t -c "SELECT COUNT(*) FROM entities_missing_embeddings;")
    echo -e "Entities missing embeddings: ${YELLOW}$missing${NC}"

    if [ "$missing" -eq 0 ]; then
        echo -e "${GREEN}All entities have embeddings!${NC}"
        return
    fi

    echo -e "\nSelect backfill strategy:"
    echo "1) Queue all at once"
    echo "2) Queue in batches of 100"
    echo "3) Queue in batches of 500"
    echo "4) Queue in batches of 1000"
    echo "5) Custom batch size"
    echo "0) Cancel"

    read -p "Choice: " choice

    case $choice in
        1)
            queue_all
            ;;
        2)
            while [ "$missing" -gt 0 ]; do
                queue_batch 100
                sleep 30
                missing=$($PSQL_CMD -t -c "SELECT COUNT(*) FROM entities_missing_embeddings;")
                echo -e "Remaining: ${YELLOW}$missing${NC}"
            done
            ;;
        3)
            while [ "$missing" -gt 0 ]; do
                queue_batch 500
                sleep 60
                missing=$($PSQL_CMD -t -c "SELECT COUNT(*) FROM entities_missing_embeddings;")
                echo -e "Remaining: ${YELLOW}$missing${NC}"
            done
            ;;
        4)
            while [ "$missing" -gt 0 ]; do
                queue_batch 1000
                sleep 120
                missing=$($PSQL_CMD -t -c "SELECT COUNT(*) FROM entities_missing_embeddings;")
                echo -e "Remaining: ${YELLOW}$missing${NC}"
            done
            ;;
        5)
            read -p "Enter batch size: " batch_size
            while [ "$missing" -gt 0 ]; do
                queue_batch "$batch_size"
                sleep 60
                missing=$($PSQL_CMD -t -c "SELECT COUNT(*) FROM entities_missing_embeddings;")
                echo -e "Remaining: ${YELLOW}$missing${NC}"
            done
            ;;
        0)
            echo "Cancelled"
            ;;
        *)
            echo -e "${RED}Invalid choice${NC}"
            ;;
    esac
}

live_monitor() {
    echo -e "${BLUE}=== Live Monitoring (Ctrl+C to stop) ===${NC}"
    while true; do
        clear
        echo -e "${BLUE}=== Embedding Queue Monitor ===${NC}"
        echo -e "Time: $(date '+%Y-%m-%d %H:%M:%S')\n"

        # Queue status
        echo -e "${YELLOW}Queue Status:${NC}"
        $PSQL_CMD -c "
        SELECT status,
               COUNT(*) as count,
               ROUND(AVG(EXTRACT(EPOCH FROM (NOW() - created_at))), 1) as avg_age_seconds
        FROM embedding_queue
        GROUP BY status;"

        # Processing rate
        echo -e "\n${YELLOW}Processing Rate (last 5 min):${NC}"
        $PSQL_CMD -c "
        SELECT COUNT(*) as completed_last_5min,
               ROUND(COUNT(*) / 5.0, 1) as per_minute
        FROM embedding_queue
        WHERE status = 'completed'
        AND processed_at > NOW() - INTERVAL '5 minutes';"

        # Worker status
        echo -e "\n${YELLOW}Worker Status:${NC}"
        if docker ps | grep -q embedding_worker; then
            echo -e "${GREEN}Running${NC}"
            docker stats --no-stream --format "CPU: {{.CPUPerc}}, Memory: {{.MemUsage}}" embedding_worker_database_of_things 2>/dev/null || true
        else
            echo -e "${RED}Not running${NC}"
        fi

        sleep 5
    done
}

# Main script
check_docker
check_database

case "${1:-}" in
    status)
        show_status
        ;;
    start)
        start_worker
        ;;
    stop)
        stop_worker
        ;;
    restart)
        restart_worker
        ;;
    logs)
        show_logs "${2:-100}"
        ;;
    queue-all)
        queue_all
        ;;
    queue-batch)
        queue_batch "${2:-100}"
        ;;
    retry-failed)
        retry_failed
        ;;
    cleanup)
        cleanup_queue
        ;;
    stats)
        show_stats
        ;;
    backfill)
        interactive_backfill
        ;;
    monitor)
        live_monitor
        ;;
    -h|--help|help)
        show_help
        ;;
    *)
        if [ -n "${1:-}" ]; then
            echo -e "${RED}Unknown command: $1${NC}\n"
        fi
        show_help
        exit 1
        ;;
esac