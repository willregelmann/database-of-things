#!/bin/bash

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Check if backup file provided
if [ -z "$1" ]; then
  echo -e "${RED}Usage: $0 <backup_file>${NC}"
  echo -e "Example: $0 backups/storage/storage_20251024_120000.tar.gz"
  exit 1
fi

BACKUP_FILE="$1"
VOLUME_NAME="supabase_storage_database-of-things"

# Check if backup file exists
if [ ! -f "${BACKUP_FILE}" ]; then
  echo -e "${RED}Error: Backup file not found: ${BACKUP_FILE}${NC}"
  exit 1
fi

# Confirmation
echo -e "${YELLOW}⚠️  WARNING: This will REPLACE all current storage contents!${NC}"
echo -e "Restoring from: ${BACKUP_FILE}"
read -p "Are you sure? (yes/no): " CONFIRM

if [ "${CONFIRM}" != "yes" ]; then
  echo "Restore cancelled."
  exit 0
fi

echo -e "${YELLOW}Restoring storage...${NC}"

# Create temporary container to restore volume
TEMP_CONTAINER="temp_storage_restore_$(date +%s)"

# Clear existing volume contents and restore from tarball
docker run --rm \
  -v "${VOLUME_NAME}:/data" \
  -v "$(pwd)/$(dirname ${BACKUP_FILE}):/backup:ro" \
  --name "${TEMP_CONTAINER}" \
  alpine:latest \
  sh -c "rm -rf /data/* /data/.* 2>/dev/null || true && tar xzf /backup/$(basename ${BACKUP_FILE}) -C /data"

echo -e "${GREEN}✓ Storage restored successfully from: ${BACKUP_FILE}${NC}"
echo -e "${GREEN}✓ Restart Supabase to apply changes: ./bin/supabase stop && ./bin/supabase start${NC}"
