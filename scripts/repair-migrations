#!/bin/bash

# Repair migration history to sync local with production
# This marks remote migrations as "reverted" so we can start fresh

echo "Repairing migration history..."
echo ""
echo "This will:"
echo "  1. Mark old remote migrations as reverted (they're already applied)"
echo "  2. Mark our new thumbnail migration as applied (once you run it)"
echo ""

read -p "Continue? [y/N]: " confirm

if [[ ! $confirm =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    exit 0
fi

echo ""
echo "Repairing..."

# Mark remote migrations as reverted (they're from a different setup)
supabase migration repair --status reverted 20251025180823
supabase migration repair --status reverted 20251025180838
supabase migration repair --status reverted 20251025180839
supabase migration repair --status reverted 20251025180841
supabase migration repair --status reverted 20251025180859
supabase migration repair --status reverted 20251025180900
supabase migration repair --status reverted 20251025180903
supabase migration repair --status reverted 20251025180953
supabase migration repair --status reverted 20251025181058
supabase migration repair --status reverted 20251025181652
supabase migration repair --status reverted 20251025181859
supabase migration repair --status reverted 20251025194338
supabase migration repair --status reverted 20251026005005

echo ""
echo "✅ Migration history repaired!"
echo ""
echo "Now you can run:"
echo "  supabase db push"
