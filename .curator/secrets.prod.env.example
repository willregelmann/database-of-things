# Production Supabase Configuration
# These credentials are for your production Supabase instance

# Get these values from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_production_service_role_key_here

# IMPORTANT: Never commit this file with real credentials
# Keep the actual secrets.prod.env in .gitignore
