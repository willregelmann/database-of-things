{
  "curator_version": "2.0",
  "collection_name": "Power Rangers Toys",
  "data_source": "https://www.grnrngr.com/toys/power-rangers/",
  "fetch": {
    "script": "scripts/fetch_data.py",
    "requires_api_key": false,
    "rate_limit_seconds": 1,
    "supports_filters": [
      {"name": "season", "type": "string", "description": "Season name or URL slug (e.g., 'mighty-morphin', 'zeo')"},
      {"name": "limit", "type": "integer", "description": "Limit number of seasons to fetch"}
    ]
  },
  "deduplication": {
    "strategy": "external_id",
    "field": "grnrngr_item_number",
    "fallback": "semantic",
    "semantic_threshold": 0.95
  },
  "entity_mapping": {
    "parent_type": "collection",
    "child_type": "action_figure",
    "attributes": ["manufacturer"]
  }
}
