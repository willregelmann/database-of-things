# Supabase Configuration
# Get these from your local Supabase instance (./bin/supabase status)
# or from your .env.local file in the project root

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your_service_key_here

# No API key needed - RangerWiki is publicly accessible

# Instructions:
# 1. Copy this file to secrets.env
# 2. Fill in your actual Supabase credentials
# 3. Run: source secrets.env
# 4. Execute scripts: ./scripts/fetch_data.py && ./scripts/import_items.py
