# Labubu Curator Configuration

# Note: Supabase credentials (SUPABASE_URL, SUPABASE_SERVICE_KEY) are
# loaded from the global .curator/secrets.env file

# Collection Configuration
# Create a "Labubu" or "THE MONSTERS" collection entity first, then paste its UUID here
# Example: Create "THE MONSTERS" collection in database, get its ID, set below
COLLECTION_ID=00000000-0000-0000-0000-000000000000

# Optional: Web Scraping Configuration
# Rate limiting (requests per second)
RATE_LIMIT_RPS=2

# Optional: Fetch limits for testing
# Uncomment to limit number of series or figures fetched
# FETCH_LIMIT=20
