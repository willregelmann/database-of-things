# Marvel Comics Curator - Shared Configuration (All Environments)

# Marvel API Keys
# Get your keys from https://developer.marvel.com
MARVEL_PUBLIC_KEY=your_public_key_here
MARVEL_PRIVATE_KEY=your_private_key_here

# Optional: Limit number of comics to fetch (for testing)
# FETCH_LIMIT=100

# Note: Environment-specific configuration (Supabase credentials, Collection IDs)
# are in separate files:
# - secrets.local.env (for local development)
# - secrets.prod.env (for production)
