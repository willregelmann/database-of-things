# Marvel API Keys
# Get your keys from https://developer.marvel.com
MARVEL_PUBLIC_KEY=your_public_key_here
MARVEL_PRIVATE_KEY=your_private_key_here

# Supabase Configuration (usually from .env.local in project root)
SUPABASE_URL=http://127.0.0.1:54321
