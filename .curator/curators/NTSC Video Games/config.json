{
  "curator_version": "2.0",
  "collection_name": "NTSC Video Games",
  "data_source": "https://www.mobygames.com",
  "fetch": {
    "script": "scripts/fetch_data.py",
    "requires_api_key": true,
    "rate_limit_seconds": 1.5,
    "supports_filters": [
      {"name": "platform", "type": "string", "description": "Platform name or ID (e.g., 'PlayStation 2', '21')"},
      {"name": "limit", "type": "integer", "description": "Number of games to fetch"}
    ]
  },
  "deduplication": {
    "strategy": "external_id",
    "field": "mobygames_game_platform_id",
    "fallback": "semantic",
    "semantic_threshold": 0.95
  },
  "entity_mapping": {
    "parent_type": "collection",
    "child_type": "video_game",
    "attributes": ["publisher", "developer"]
  }
}
