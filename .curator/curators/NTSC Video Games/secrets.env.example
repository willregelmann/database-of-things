# NTSC Video Games Curator - Shared Configuration (All Environments)

# MobyGames API credentials
# Get your API key from https://www.mobygames.com/info/api/
MOBY_GAMES_API_KEY=your_mobygames_api_key_here

# Fetch configuration
FETCH_LIMIT=30
FETCH_OFFSET=0
TITLE_SEARCH=Pokémon

# Note: Environment-specific configuration (Supabase credentials, Collection IDs)
# are in separate files:
# - secrets.local.env (for local development)
# - secrets.prod.env (for production)
