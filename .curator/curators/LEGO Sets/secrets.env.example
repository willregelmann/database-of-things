# Rebrickable API Configuration
# Get your API key at: https://rebrickable.com/api/
REBRICKABLE_API_KEY=your_api_key_here

# Supabase Configuration
# For local development, use:
#   SUPABASE_URL=http://127.0.0.1:54321
#   SUPABASE_SERVICE_KEY=<from ./bin/supabase status>
#
# For production, use your Supabase Cloud credentials:
SUPABASE_URL=https://cogxqhlogmagvgicaccg.supabase.co
SUPABASE_SERVICE_KEY=your_production_service_role_key_here

# Collection Configuration
# Create a theme collection entity first, then paste its UUID here
# Example: Create "Super Mario" collection in database, get its ID, set below
COLLECTION_ID=00000000-0000-0000-0000-000000000000

# Runtime Configuration
# The LEGO theme to import (e.g., "Super Mario", "Star Wars", "City", "Technic")
# This is the primary runtime filter - change this to import different themes
THEME_NAME="Super Mario"

# Optional: Limit number of sets to fetch (useful for testing)
# Uncomment for testing with small sample
# FETCH_LIMIT=10
