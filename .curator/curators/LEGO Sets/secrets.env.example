# Rebrickable API Configuration
# Get your API key at: https://rebrickable.com/api/
REBRICKABLE_API_KEY=your_api_key_here

# Supabase Configuration
# Local development (use these for local testing)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your_local_service_key_from_supabase_status

# Production (uncomment and use these for production imports)
# SUPABASE_URL=https://yourproject.supabase.co
# SUPABASE_SERVICE_KEY=your_production_service_key

# Collection Configuration
# Create a theme collection entity first, then paste its UUID here
# Example: Create "Space" collection in database, get its ID, set below
COLLECTION_ID=00000000-0000-0000-0000-000000000000

# Runtime Configuration
# The LEGO theme to import (e.g., "Space", "Star Wars", "City", "Technic")
# This is the primary runtime filter - change this to import different themes
THEME_NAME=Space

# Optional: Limit number of sets to fetch (useful for testing)
# Comment out or remove to fetch all sets in theme
# FETCH_LIMIT=10
