{
  "curator_version": "2.0",
  "collection_name": "Pokemon TCG",
  "data_source": "https://github.com/PokemonTCG/pokemon-tcg-data",
  "fetch": {
    "script": "scripts/fetch_data.py",
    "requires_api_key": false,
    "rate_limit_seconds": 0,
    "supports_filters": ["limit", "series", "set"]
  },
  "deduplication": {
    "strategy": "external_id",
    "field": "pokemontcg_io",
    "fallback": "semantic",
    "semantic_threshold": 0.95
  },
  "entity_mapping": {
    "type": "item",
    "category": "trading_card_games",
    "attributes": ["rarity", "artist"]
  }
}
