# Supabase Configuration
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your-service-key-here

# LLM Provider Selection (openai, google, anthropic)
LLM_PROVIDER=google

# OpenAI Configuration (if using openai provider)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-5-nano
# Note: Mem0 uses gpt-4o-mini (configured in config/mem0_*.json) because it doesn't support GPT-5's new API yet

# Google Gemini Configuration (if using google provider)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash

# Anthropic Configuration (if using anthropic provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Mem0 Configuration (optional - only if using hosted Mem0)
# MEM0_API_KEY=your-mem0-api-key-here

# Redis Configuration (for rate limiting & caching)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password-here

# AWS S3 Configuration (for DeepAgents persistence)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_MEMORIES=curator-memories
S3_BUCKET_WORKFLOWS=curator-workflows

# Token Budget Management
DAILY_TOKEN_LIMIT=1000000
TOKEN_BUFFER_PERCENTAGE=0.1

# Rate Limiting
API_RATE_LIMIT_PER_SECOND=0.5
MAX_RETRY_ATTEMPTS=3
EXPONENTIAL_BACKOFF_BASE=2

# Progress Monitoring
PROGRESS_UPDATE_INTERVAL=5

# Image Processing
IMAGE_MAX_SIZE_MB=5
THUMBNAIL_SIZE=300
THUMBNAIL_QUALITY=85

# DeepAgents
DEEPAGENTS_BASE_PATH=/tmp/curator_agents

# LangGraph Platform
LANGGRAPH_URL=http://localhost:8000
